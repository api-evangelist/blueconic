{
  "@context": {
    "@vocab": "https://schema.org/",
    "blueconic": "https://api.blueconic.com/vocab#",
    "api": "https://api-evangelist.github.io/blueconic/vocab#",
    "Profile": "blueconic:Profile",
    "VisitorProfile": "blueconic:VisitorProfile",
    "Segment": "blueconic:Segment",
    "LifecycleStage": "blueconic:LifecycleStage",
    "Connection": "blueconic:Connection",
    "Dialogue": "blueconic:Dialogue",
    "Listener": "blueconic:Listener",
    "ProfileProperty": "blueconic:ProfileProperty",
    "Interaction": "blueconic:Interaction",
    "TimelineEvent": "blueconic:TimelineEvent",
    "Recommendation": "blueconic:Recommendation",
    "Group": "blueconic:Group",
    "GroupType": "blueconic:GroupType",
    "Objective": "blueconic:Objective",
    "Notebook": "blueconic:Notebook",
    "AuditEvent": "blueconic:AuditEvent",
    "ContentStore": "blueconic:ContentStore",
    "ContentItem": "blueconic:ContentItem",
    "Channel": "blueconic:Channel",
    "Role": "blueconic:Role",
    "User": "blueconic:User",
    "Model": "blueconic:Model",
    "URLMapping": "blueconic:URLMapping",
    "profileId": "blueconic:profileId",
    "profileProperties": "blueconic:profileProperties",
    "segments": "blueconic:segments",
    "lifecycleStage": "blueconic:lifecycleStage",
    "permissions": "blueconic:permissions",
    "events": "blueconic:events",
    "name": "schema:name",
    "description": "schema:description",
    "identifier": "schema:identifier",
    "email": "schema:email",
    "url": "schema:url",
    "dateCreated": {
      "@id": "schema:dateCreated",
      "@type": "schema:Date"
    },
    "dateModified": {
      "@id": "schema:dateModified",
      "@type": "schema:Date"
    },
    "tenant": "blueconic:tenant",
    "clientId": "blueconic:clientId",
    "accessToken": "blueconic:accessToken",
    "refreshToken": "blueconic:refreshToken",
    "scope": "blueconic:scope",
    "connectionStatus": "blueconic:connectionStatus",
    "connectionRun": "blueconic:connectionRun",
    "targetChannels": "blueconic:targetChannels",
    "criteria": "blueconic:criteria",
    "refinement": "blueconic:refinement",
    "segmentSize": "blueconic:segmentSize",
    "reportingEntry": "blueconic:reportingEntry",
    "dialogueReporting": "blueconic:dialogueReporting",
    "links": {
      "@id": "blueconic:links",
      "@container": "@set"
    }
  }
}