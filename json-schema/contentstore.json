{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api-evangelist.github.io/blueconic/json-schema/contentstore.json",
  "title": "contentStore",
  "type": "object",
  "properties": {
    "creationDate": {
      "type": "string",
      "format": "date-time",
      "description": "The creation date of the object. Datetime in UTC in the https://www.ietf.org/rfc/rfc3339.txt format, example = \"2025-01-22T11:21:33.872Z\".",
      "readOnly": true
    },
    "creator": {
      "$ref": "#/components/schemas/UserBean"
    },
    "description": {
      "type": "string",
      "description": "The description."
    },
    "id": {
      "type": "string",
      "description": "The object ID."
    },
    "itemCount": {
      "type": "integer",
      "format": "int32",
      "description": "The number of items in the store.",
      "readOnly": true
    },
    "lastModifiedDate": {
      "type": "string",
      "format": "date-time",
      "description": "The last modified date of the object. Datetime in UTC in the https://www.ietf.org/rfc/rfc3339.txt format, example = \"2025-01-22T11:21:33.872Z\".",
      "readOnly": true
    },
    "lastModifiedUser": {
      "$ref": "#/components/schemas/UserBean"
    },
    "name": {
      "type": "string",
      "description": "The object name."
    },
    "properties": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/property"
      }
    },
    "storeType": {
      "type": "string",
      "description": "The store type.",
      "enum": [
        "CONTENT",
        "PRODUCT"
      ]
    },
    "tags": {
      "type": "array",
      "description": "The tags (i.e. labels).",
      "example": "Address",
      "items": {
        "type": "string",
        "description": "The tags (i.e. labels).",
        "example": "Address"
      }
    }
  }
}